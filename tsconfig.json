{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./bridge",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["bridge/**/*"],
  "exclude": ["node_modules", "dist", "example", "tests"]
}
